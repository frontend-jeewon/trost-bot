{
  "name": "trost-vacation-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Weekly vacation summary: read flex bot messages from a source Slack channel and post to a target channel as a thread.",
  "scripts": {
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "dry-run": "DRY_RUN=1 tsx --env-file-if-exists=.env src/index.ts",
    "test": "node --import tsx --test test/parser.test.ts",
    "typecheck": "tsc --noEmit",
    "list-groups": "tsx --env-file-if-exists=.env scripts/list-user-groups.ts"
  },
  "engines": {
    "node": ">=20.16.0"
  },
  "dependencies": {
    "@slack/web-api": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
