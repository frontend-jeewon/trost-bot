# Slack Bot Token (xoxb-...)
# 필요한 OAuth Scopes: channels:history, chat:write, usergroups:read, users:read
SLACK_BOT_TOKEN=xoxb-xxx

# 휴가 메시지가 등록되는 채널 (#넋지_자리비움)
SLACK_SOURCE_CHANNEL_ID=C01RYV15VV5

# 주간 요약을 게시할 채널
SLACK_TARGET_CHANNEL_ID=C01HGG52PC1

# 대상 인원 슬랙 User Group ID (S로 시작, npm run list-groups 로 확인 가능)
SLACK_USER_GROUP_ID=S0XXXXXXXX

# 소스 채널을 몇 일치 거슬러 올라가서 읽을지 (기본 60)
# LOOKBACK_DAYS=60

# 오늘부터 몇 일 후까지의 휴가를 보여줄지 (기본 7)
# HORIZON_DAYS=7

# 1로 설정하면 슬랙에 보내지 않고 콘솔에 출력만 함
# DRY_RUN=1
